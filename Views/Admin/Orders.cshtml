@model List<LuxeThreads.Models.Order>
@{
    ViewData["Title"] = "Orders";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Orders — LuxeThreads Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<div class="admin-layout">
    <aside class="admin-sidebar">
        <div class="admin-brand">LUXE<span>THREADS</span></div>
        <nav class="admin-nav">
            <a href="/Admin" class="admin-nav-item"><i class="fa fa-gauge-high"></i> <span>Dashboard</span></a>
            <a href="/Admin/Products" class="admin-nav-item"><i class="fa fa-shirt"></i> <span>Products</span></a>
            <a href="/Admin/Orders" class="admin-nav-item active"><i class="fa fa-box"></i> <span>Orders</span></a>
            <a href="/Admin/AddProduct" class="admin-nav-item"><i class="fa fa-plus"></i> <span>Add Product</span></a>
        </nav>
        <div style="padding:1.5rem 2rem; border-top:1px solid var(--border);">
            <a href="/" class="admin-nav-item" style="padding:0;"><i class="fa fa-store"></i> <span>View Store</span></a>
            <a href="/Account/Logout" class="admin-nav-item" style="padding:0.5rem 0 0;"><i class="fa fa-right-from-bracket"></i> <span>Logout</span></a>
        </div>
    </aside>
    <main class="admin-content">
        <div class="admin-topbar">
            <h2>All Orders</h2>
            <span style="font-size:0.82rem; color:var(--warm-gray);">@Model.Count total orders</span>
        </div>
        <div class="admin-body">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Order #</th>
                        <th>Customer</th>
                        <th>Email</th>
                        <th>Address</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model.OrderByDescending(x => x.OrderDate))
                    {
                        <tr>
                            <td><strong>#@o.Id</strong></td>
                            <td>@o.CustomerName</td>
                                <td style="color:var(--warm-gray); font-size:0.82rem;">@o.UserEmail</td>
                            <td style="color:var(--warm-gray); font-size:0.82rem;">@o.Address</td>
                            <td><strong>PKR @o.Total.ToString("N0")</strong></td>
                            <td><span class="status-badge status-@o.Status.ToLower()">@o.Status</span></td>
                            <td style="color:var(--warm-gray); font-size:0.82rem;">@o.OrderDate.ToString("MMM d, yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </main>
</div>
</body>
</html>
