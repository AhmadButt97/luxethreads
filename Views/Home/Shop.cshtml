@model LuxeThreads.Models.ShopViewModel
@{
    ViewData["Title"] = "Shop – LuxeThreads";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    * { box-sizing: border-box; }
    body { background: #f8f6f1; }

    .shop-header {
        background: linear-gradient(135deg, #1a1a2e, #16213e);
        color: white; padding: 50px 0; text-align: center;
    }
    .shop-header h1 { font-size: 42px; font-family: Georgia, serif; }
    .shop-header p { color: #c9a96e; letter-spacing: 2px; font-size: 13px; margin-top: 8px; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }

    /* ── Filter bar ── */
    .filter-bar {
        background: white; border-bottom: 1px solid #eee;
        padding: 18px 0; position: sticky; top: 0; z-index: 100;
    }
    .filter-inner {
        display: flex; flex-wrap: wrap; gap: 12px; align-items: center; justify-content: space-between;
    }
    .filter-cats { display: flex; gap: 10px; flex-wrap: wrap; }
    .filter-btn {
        padding: 8px 20px; border: 1px solid #ddd; background: white;
        cursor: pointer; font-size: 13px; letter-spacing: .5px; transition: all .2s;
        text-decoration: none; color: #333;
    }
    .filter-btn:hover, .filter-btn.active {
        background: #1a1a2e; color: white; border-color: #1a1a2e;
    }
    .search-form { display: flex; gap: 8px; }
    .search-input {
        padding: 8px 16px; border: 1px solid #ddd; font-size: 14px;
        outline: none; width: 220px;
    }
    .search-input:focus { border-color: #c9a96e; }
    .search-btn {
        background: #c9a96e; color: #1a1a2e; border: none;
        padding: 8px 18px; cursor: pointer; font-weight: 700; font-size: 13px;
    }

    /* ── Grid ── */
    .shop-body { padding: 50px 0; }
    .results-info { margin-bottom: 24px; color: #666; font-size: 14px; }
    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 28px;
    }

    /* ── Card ── */
    .product-card {
        background: white; overflow: hidden;
        border: 1px solid #eee; transition: box-shadow .25s;
    }
    .product-card:hover { box-shadow: 0 10px 35px rgba(0,0,0,.13); }
    .product-img {
        position: relative; height: 300px; overflow: hidden; background: #1a1a2e;
    }
    .product-img img {
        width: 100%; height: 100%; object-fit: cover; transition: transform .4s;
    }
    .product-card:hover .product-img img { transform: scale(1.06); }
    .badge {
        position: absolute; top: 12px; left: 12px;
        background: #c9a96e; color: #1a1a2e;
        font-size: 10px; font-weight: 800; padding: 4px 10px; letter-spacing: 1.5px;
    }
    .badge-sale { background: #e74c3c; color: white; }
    .out-badge {
        position: absolute; inset: 0;
        background: rgba(0,0,0,.5); display: flex;
        align-items: center; justify-content: center;
        color: white; font-size: 16px; font-weight: 700; letter-spacing: 2px;
    }

    .product-info { padding: 18px 18px 20px; }
    .product-cat { font-size: 11px; color: #c9a96e; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 6px; }
    .product-name { font-size: 16px; font-weight: 600; margin-bottom: 6px; }
    .product-desc { font-size: 13px; color: #777; margin-bottom: 14px; line-height: 1.5; }
    .price-row { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
    .price { color: #c9a96e; font-size: 22px; font-weight: 700; }
    .old-price { text-decoration: line-through; color: #bbb; font-size: 15px; }
    .card-actions { display: flex; gap: 8px; }
    .btn-cart {
        flex: 1; background: #1a1a2e; color: white; border: none;
        padding: 11px; cursor: pointer; font-size: 12px;
        letter-spacing: 1px; font-weight: 700; transition: background .2s;
    }
    .btn-cart:hover { background: #c9a96e; color: #1a1a2e; }
    .btn-detail {
        padding: 11px 16px; border: 1px solid #1a1a2e; background: white;
        color: #1a1a2e; text-decoration: none; font-size: 12px;
        font-weight: 700; transition: all .2s; white-space: nowrap;
    }
    .btn-detail:hover { background: #1a1a2e; color: white; }

    /* ── Empty ── */
    .empty-state { text-align: center; padding: 80px 20px; grid-column: 1/-1; }
    .empty-state h3 { font-size: 24px; margin-bottom: 12px; }
    .empty-state a { color: #c9a96e; }
</style>

<!-- ── PAGE HEADER ── -->
<div class="shop-header">
    <h1>Our Collection</h1>
    <p>PREMIUM QUALITY · MODERN STYLE · TIMELESS DESIGN</p>
</div>

<!-- ── FILTER BAR ── -->
<div class="filter-bar">
    <div class="container">
        <div class="filter-inner">
            <div class="filter-cats">
                <a href="/Home/Shop" class="filter-btn @(string.IsNullOrEmpty(Model.Category) ? "active" : "")">All</a>
                @foreach (var cat in Model.Categories)
                {
                    <a href="/Home/Shop?category=@cat"
                       class="filter-btn @(Model.Category == cat ? "active" : "")">@cat</a>
                }
            </div>
            <form method="get" action="/Home/Shop" class="search-form">
                @if (!string.IsNullOrEmpty(Model.Category))
                {
                    <input type="hidden" name="category" value="@Model.Category">
                }
                <input type="text" name="search" value="@Model.Search"
                       placeholder="Search products..." class="search-input">
                <button type="submit" class="search-btn">Search</button>
            </form>
        </div>
    </div>
</div>

<!-- ── PRODUCTS ── -->
<div class="shop-body">
    <div class="container">
        <p class="results-info">
            @Model.Products.Count product@(Model.Products.Count != 1 ? "s" : "") found
            @if (!string.IsNullOrEmpty(Model.Category)) { <text> in <strong>@Model.Category</strong></text> }
            @if (!string.IsNullOrEmpty(Model.Search)) { <text> for "<strong>@Model.Search</strong>"</text> }
        </p>

        <div class="products-grid">
            @if (Model.Products.Any())
            {
                @foreach (var p in Model.Products)
                {
                    <div class="product-card">
                        <div class="product-img">
                            <img src="@p.ImageUrl"
                                 alt="@p.Name"
                                 onerror="this.src='https://images.unsplash.com/photo-1523381210434-271e8be1f52b?w=600&q=80'">
                            @if (!string.IsNullOrEmpty(p.Badge))
                            {
                                <span class="badge @(p.Badge == "SALE" ? "badge-sale" : "")">@p.Badge</span>
                            }
                            @if (!p.IsAvailable)
                            {
                                <div class="out-badge">OUT OF STOCK</div>
                            }
                        </div>
                        <div class="product-info">
                            <p class="product-cat">@p.Category</p>
                            <h3 class="product-name">@p.Name</h3>
                            <p class="product-desc">@p.Description</p>
                            <div class="price-row">
                                <span class="price">$@p.Price.ToString("F2")</span>
                                @if (p.OldPrice > 0)
                                {
                                    <span class="old-price">$@p.OldPrice.ToString("F2")</span>
                                }
                            </div>
                            <div class="card-actions">
                                @if (p.IsAvailable)
                                {
                                    <form method="post" action="/Home/AddToCart" style="flex:1; display:flex;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@p.Id">
                                        <input type="hidden" name="size" value="M">
                                        <input type="hidden" name="quantity" value="1">
                                        <button type="submit" class="btn-cart">ADD TO CART</button>
                                    </form>
                                }
                                else
                                {
                                    <button class="btn-cart" disabled style="opacity:.5;cursor:not-allowed;">SOLD OUT</button>
                                }
                                <a href="/Home/Product/@p.Id" class="btn-detail">VIEW</a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <h3>No products found</h3>
                    <p>Try a different category or <a href="/Home/Shop">view all products</a>.</p>
                </div>
            }
        </div>
    </div>
</div>
