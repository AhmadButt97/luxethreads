@model List<LuxeThreads.Models.Product>
@{
    ViewData["Title"] = "LuxeThreads";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    .hero {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        color: white;
        padding: 100px 0;
    }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
    .btn-gold {
        background: #c9a96e; color: #1a1a2e; padding: 14px 35px;
        text-decoration: none; display: inline-block;
        font-weight: 700; letter-spacing: 1px; border: none; cursor: pointer;
        transition: opacity .2s;
    }
    .btn-gold:hover { opacity: .85; }
    .btn-outline {
        border: 2px solid white; color: white; padding: 14px 35px;
        text-decoration: none; display: inline-block; background: transparent;
        font-weight: 700; letter-spacing: 1px; transition: all .2s;
    }
    .btn-outline:hover { background: white; color: #1a1a2e; }

    /* ── Products ── */
    .section { padding: 70px 0; }
    .section-title { text-align: center; font-size: 38px; margin-bottom: 50px; font-family: Georgia, serif; }
    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 30px;
    }
    .product-card {
        border: 1px solid #eee; background: white;
        transition: box-shadow .2s; overflow: hidden;
    }
    .product-card:hover { box-shadow: 0 8px 30px rgba(0,0,0,.12); }
    .product-img {
        position: relative; height: 280px; overflow: hidden; background: #1a1a2e;
    }
    .product-img img {
        width: 100%; height: 100%; object-fit: cover;
        transition: transform .4s;
    }
    .product-card:hover .product-img img { transform: scale(1.05); }
    .badge {
        position: absolute; top: 12px; left: 12px;
        background: #c9a96e; color: #1a1a2e;
        font-size: 11px; font-weight: 700; padding: 4px 10px; letter-spacing: 1px;
    }
    .product-info { padding: 18px; text-align: center; }
    .product-info h3 { font-size: 16px; margin-bottom: 8px; }
    .price { color: #c9a96e; font-size: 20px; font-weight: 700; margin-bottom: 14px; }
    .old-price { text-decoration: line-through; color: #999; font-size: 14px; margin-left: 6px; }
    .btn-cart {
        background: #1a1a2e; color: white; border: none;
        padding: 10px 24px; cursor: pointer; width: 100%;
        font-size: 13px; letter-spacing: 1px; font-weight: 600;
        transition: background .2s;
    }
    .btn-cart:hover { background: #c9a96e; color: #1a1a2e; }

    /* ── Categories ── */
    .bg-light { background: #f8f6f1; padding: 70px 0; }
    .categories-grid {
        display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 24px;
    }
    .category-card {
        background: white; padding: 40px 20px; text-align: center;
        border: 1px solid #eee; transition: box-shadow .2s;
    }
    .category-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,.1); }
    .category-icon { font-size: 42px; margin-bottom: 14px; }
    .category-card h3 { margin-bottom: 12px; font-size: 17px; }
    .category-card a { color: #c9a96e; text-decoration: none; font-weight: 600; }

    /* ── Banner ── */
    .banner {
        background: linear-gradient(135deg, #c9a96e, #b8935a);
        color: #1a1a2e; text-align: center; padding: 60px 20px;
    }
    .banner h2 { font-size: 32px; margin-bottom: 10px; }
    .banner p { font-size: 16px; margin-bottom: 24px; }
    .btn-dark {
        background: #1a1a2e; color: white; padding: 14px 35px;
        text-decoration: none; font-weight: 700; letter-spacing: 1px;
        display: inline-block; transition: opacity .2s;
    }
    .btn-dark:hover { opacity: .85; }

    /* No products fallback */
    .no-products { text-align: center; padding: 40px; color: #999; grid-column: 1/-1; }
</style>

<!-- ── HERO ── -->
<section class="hero">
    <div class="container">
        <div style="display:flex; flex-wrap:wrap; align-items:center; gap:40px;">
            <div style="flex:1; min-width:280px;">
                <p style="color:#c9a96e; letter-spacing:3px; font-size:13px; margin-bottom:16px;">NEW COLLECTION 2025</p>
                <h1 style="font-size:52px; line-height:1.15; margin-bottom:20px; font-family:Georgia,serif;">
                    Elevate Your Style with <span style="color:#c9a96e;">LuxeThreads</span>
                </h1>
                <p style="font-size:17px; margin-bottom:34px; color:#ccc; line-height:1.6;">
                    Discover premium quality clothing that blends comfort with sophistication.
                </p>
                <a href="/Home/Shop" class="btn-gold" style="margin-right:14px;">Shop Now</a>
                <a href="#featured" class="btn-outline">Explore</a>
            </div>
            <div style="flex:1; min-width:280px;">
                <img src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=700&q=80"
                     style="width:100%; border-radius:4px; box-shadow:0 20px 60px rgba(0,0,0,.4);"
                     alt="LuxeThreads Collection">
            </div>
        </div>
    </div>
</section>

<!-- ── FEATURED PRODUCTS (from DB) ── -->
<section id="featured" class="section">
    <div class="container">
        <h2 class="section-title">Featured <span style="color:#c9a96e;">Pieces</span></h2>
        <div class="products-grid">
            @if (Model != null && Model.Any())
            {
                @foreach (var p in Model)
                {
                    <div class="product-card">
                        <div class="product-img">
                            <img src="@p.ImageUrl"
                                 alt="@p.Name"
                                 onerror="this.src='https://images.unsplash.com/photo-1523381210434-271e8be1f52b?w=600&q=80'">
                            @if (!string.IsNullOrEmpty(p.Badge))
                            {
                                <span class="badge">@p.Badge</span>
                            }
                        </div>
                        <div class="product-info">
                            <h3>@p.Name</h3>
                            <div>
                                <span class="price">$@p.Price.ToString("F2")</span>
                                @if (p.OldPrice > 0)
                                {
                                    <span class="old-price">$@p.OldPrice.ToString("F2")</span>
                                }
                            </div>
                            <form method="post" action="/Home/AddToCart" style="margin-top:12px;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@p.Id">
                                <input type="hidden" name="size" value="M">
                                <input type="hidden" name="quantity" value="1">
                                <button type="submit" class="btn-cart">ADD TO CART</button>
                            </form>
                        </div>
                    </div>
                }
            }
            else
            {
                <!-- Fallback: show all products if none are marked IsFeatured -->
                <div class="no-products">
                    <p>No featured products yet. <a href="/Home/Shop" style="color:#c9a96e;">Browse all products →</a></p>
                </div>
            }
        </div>
        <div style="text-align:center; margin-top:40px;">
            <a href="/Home/Shop" class="btn-gold">View All Products</a>
        </div>
    </div>
</section>

<!-- ── CATEGORIES ── -->
<section class="bg-light">
    <div class="container">
        <h2 class="section-title">Shop by <span style="color:#c9a96e;">Category</span></h2>
        <div class="categories-grid">
            <div class="category-card">
                <div class="category-icon">👕</div>
                <h3>T-Shirts</h3>
                <a href="/Home/Shop?category=T-Shirts">Shop Now →</a>
            </div>
            <div class="category-card">
                <div class="category-icon">🧥</div>
                <h3>Jackets</h3>
                <a href="/Home/Shop?category=Jackets">Shop Now →</a>
            </div>
            <div class="category-card">
                <div class="category-icon">👖</div>
                <h3>Bottoms</h3>
                <a href="/Home/Shop?category=Bottoms">Shop Now →</a>
            </div>
            <div class="category-card">
                <div class="category-icon">🧣</div>
                <h3>Hoodies</h3>
                <a href="/Home/Shop?category=Hoodies">Shop Now →</a>
            </div>
        </div>
    </div>
</section>

<!-- ── PROMO BANNER ── -->
<section class="banner">
    <div class="container">
        <h2>New Season. New You.</h2>
        <p>Free shipping on all orders over $150. Use code <strong>LUXE25</strong> for 25% off your first order.</p>
        <a href="/Home/Shop" class="btn-dark">Shop the Sale</a>
    </div>
</section>
